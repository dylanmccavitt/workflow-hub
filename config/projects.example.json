{
  "schemaVersion": 1,
  "projects": [
    {
      "id": "chores",
      "displayName": "ChoreLadder / Still Haven't",
      "linear": {
        "teamKey": "AGE"
      },
      "repo": {
        "canonicalPath": "~/projects/chores",
        "canonicalBranch": "main"
      },
      "worktrees": {
        "roots": [
          "~/.codex/symphony-workspaces/chores",
          "~/.codex/worktrees"
        ],
        "issuePathTemplate": "{issueId}",
        "branchTemplate": "feat/{issueIdLower}-{slug}"
      },
      "ios": {
        "projectPath": "ChoreLadder.xcodeproj",
        "scheme": "ChoreLadder",
        "bundleId": "com.dylanmccavitt.choreladder",
        "simulatorName": "iPhone 17 Pro",
        "derivedDataRoot": "/tmp"
      }
    },
    {
      "id": "workflow-hub",
      "displayName": "Workflow Hub",
      "linear": {
        "teamKey": "AGE",
        "projectId": "50a8c298-e3fd-4617-bf7e-8db2cd7331b7",
        "projectSlug": "workflow-hub"
      },
      "repo": {
        "canonicalPath": "~/projects/workflow-hub",
        "canonicalBranch": "main"
      },
      "worktrees": {
        "roots": [
          "~/.codex/symphony-workspaces/workflow-hub",
          "~/.codex/worktrees"
        ],
        "issuePathTemplate": "{issueId}",
        "branchTemplate": "feat/{issueIdLower}-{slug}"
      },
      "runners": {
        "codex": {
          "command": "codex",
          "sandbox": "workspace-write",
          "approvalPolicy": "never"
        },
        "cursor": {
          "model": "composer-2",
          "configPath": ".cursor",
          "apiKeyEnv": "CURSOR_API_KEY",
          "cloud": {
            "enabled": false,
            "apiKeyEnv": "CURSOR_API_KEY",
            "repositoryUrl": "https://github.com/DylanMcCavitt/workflow-hub",
            "startingRef": "main",
            "environment": {
              "type": "cloud"
            },
            "autoCreatePR": true,
            "workOnCurrentBranch": false,
            "skipReviewerRequest": false
          }
        }
      }
    }
  ]
}
