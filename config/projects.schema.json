{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-hub.local/schemas/projects.schema.json",
  "title": "Workflow Hub project registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projects"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "envVarName": {
      "type": "string",
      "pattern": "^[A-Z_][A-Z0-9_]*$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "repo", "worktrees"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "displayName": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "linear": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "teamKey": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "projectId": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "projectSlug": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "repo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["canonicalPath"],
          "properties": {
            "canonicalPath": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "canonicalBranch": {
              "$ref": "#/$defs/nonEmptyString",
              "default": "main"
            }
          }
        },
        "worktrees": {
          "type": "object",
          "additionalProperties": false,
          "required": ["roots"],
          "properties": {
            "roots": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "issuePathTemplate": {
              "$ref": "#/$defs/nonEmptyString",
              "default": "{issueId}"
            },
            "branchTemplate": {
              "$ref": "#/$defs/nonEmptyString",
              "default": "feat/{issueIdLower}-{slug}"
            }
          }
        },
        "runners": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cursor": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "model": {
                  "$ref": "#/$defs/nonEmptyString",
                  "default": "composer-2"
                },
                "configPath": {
                  "$ref": "#/$defs/nonEmptyString",
                  "default": ".cursor"
                },
                "apiKeyEnv": {
                  "$ref": "#/$defs/envVarName",
                  "default": "CURSOR_API_KEY"
                },
                "cloud": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "apiKeyEnv": {
                      "$ref": "#/$defs/envVarName",
                      "default": "CURSOR_API_KEY"
                    },
                    "baseUrl": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "repositoryUrl": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "startingRef": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "environment": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "type": {
                          "enum": ["cloud", "pool", "machine"],
                          "default": "cloud"
                        },
                        "name": {
                          "$ref": "#/$defs/nonEmptyString"
                        }
                      }
                    },
                    "autoCreatePR": {
                      "type": "boolean",
                      "default": true
                    },
                    "workOnCurrentBranch": {
                      "type": "boolean",
                      "default": false
                    },
                    "skipReviewerRequest": {
                      "type": "boolean",
                      "default": false
                    }
                  }
                }
              }
            },
            "codex": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "command": {
                  "$ref": "#/$defs/nonEmptyString",
                  "default": "codex"
                },
                "model": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "profile": {
                  "$ref": "#/$defs/nonEmptyString"
                },
                "sandbox": {
                  "enum": ["read-only", "workspace-write"],
                  "default": "workspace-write"
                },
                "approvalPolicy": {
                  "enum": ["untrusted", "on-request", "on-failure", "never"],
                  "default": "never"
                },
                "logRoot": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              }
            }
          }
        },
        "ios": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "bundleId"],
          "properties": {
            "projectPath": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "workspacePath": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "scheme": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "bundleId": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "simulatorName": {
              "$ref": "#/$defs/nonEmptyString",
              "default": "iPhone 17 Pro"
            },
            "derivedDataRoot": {
              "$ref": "#/$defs/nonEmptyString",
              "default": "/tmp"
            }
          },
          "anyOf": [
            {
              "required": ["projectPath"]
            },
            {
              "required": ["workspacePath"]
            }
          ]
        }
      }
    }
  }
}
